# =====================================================
# Meta Ads — Marketing API
# =====================================================
# Token de acesso long-lived (System User token recomendado)
META_ACCESS_TOKEN=EAA...

# Versão da Graph API (atual: v20.0)
META_API_VERSION=v20.0

# Account IDs no formato act_XXXXXXXXXX
# Larroudé US
META_ACCOUNT_US_MAIN=act_000000000000000
META_ACCOUNT_US_PREORDER=act_000000000000000

# Larroudé BR
META_ACCOUNT_BR_MAIN=act_000000000000000
META_ACCOUNT_BR_PREORDER=act_000000000000000

# =====================================================
# Cron security (Vercel)
# =====================================================
# Vercel Cron sends Authorization: Bearer ${CRON_SECRET}
# Set this to a random string (≥32 chars). Required only on Vercel.
CRON_SECRET=

# =====================================================
# App
# =====================================================
NEXT_PUBLIC_APP_NAME="Larroudé · Meta Ads"
DEFAULT_REGION=US
DEFAULT_PERIOD=28d
